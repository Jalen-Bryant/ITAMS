@page "/account/change-password"
@attribute [Authorize]
@inject AuthService AuthService

<section class="page-header">
    <div>
        <p class="eyebrow">Security</p>
        <h1>Change Password</h1>
        <p class="page-intro">This uses the current authenticated change-password endpoint already exposed by the API.</p>
    </div>
</section>

<section class="form-page">
    <article class="editor-card editor-card-narrow">
        <MessagePanel Messages="@_messages" CssClass="@_messageClass" />

        <EditForm Model="@_formModel" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="field-group">
                <label for="currentPassword">Current Password</label>
                <InputText id="currentPassword" type="password" class="input-control" @bind-Value="_formModel.CurrentPassword" />
            </div>

            <div class="field-group">
                <label for="newPassword">New Password</label>
                <InputText id="newPassword" type="password" class="input-control" @bind-Value="_formModel.NewPassword" />
            </div>

            <div class="field-group">
                <label for="verifyPassword">Verify New Password</label>
                <InputText id="verifyPassword" type="password" class="input-control" @bind-Value="_formModel.VerifyPassword" />
            </div>

            <button class="button button-primary" type="submit" disabled="@_isSubmitting">
                @(_isSubmitting ? "Updating..." : "Update Password")
            </button>
        </EditForm>
    </article>
</section>

@code {
    private readonly ChangePasswordFormModel _formModel = new();
    private readonly List<string> _messages = [];
    private bool _isSubmitting;
    private string _messageClass = "message-panel message-panel-success";

    private async Task HandleSubmitAsync()
    {
        _messages.Clear();
        _isSubmitting = true;

        try
        {
            await AuthService.ChangePasswordAsync(_formModel);
            _messageClass = "message-panel message-panel-success";
            _messages.Add("Password updated successfully.");
            _formModel.CurrentPassword = string.Empty;
            _formModel.NewPassword = string.Empty;
            _formModel.VerifyPassword = string.Empty;
        }
        catch (ApiException exception)
        {
            _messageClass = "message-panel message-panel-error";
            _messages.AddRange(exception.GetMessages());
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
